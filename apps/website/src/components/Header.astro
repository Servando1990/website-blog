---
import { bookingUrl } from '../lib/siteContent';

const pathname = Astro.url.pathname;

const links = [
  { href: '/case-studies', label: 'Case studies' },
  { href: '/#product', label: 'Product' },
  { href: '/blog', label: 'Writing' },
  { href: '/tools', label: 'Tools' },
];

function isActive(href: string) {
  if (href.startsWith('/#')) {
    return false;
  }

  return pathname.startsWith(href);
}
---

<header class="site-header">
  <div class="wrap">
    <nav class="site-nav" aria-label="Primary">
      <a class="brand" href="/">
        <svg class="brand__mark" width="16" height="16" viewBox="0 0 512 512" fill="none" aria-hidden="true">
          <path d="M112 152V280H368" stroke="currentColor" stroke-width="40" stroke-linecap="round" stroke-linejoin="round"></path>
          <path d="M368 280L304 216M368 280L304 344" stroke="currentColor" stroke-width="40" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <span class="brand__word">controlthrive</span>
      </a>

      <div class="nav-links">
        {links.map((link) => (
          <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
            {link.label}
          </a>
        ))}
      </div>

      <a class="btn-ink nav-cta" href={bookingUrl} target="_blank" rel="noopener noreferrer">
        Book a founder call
      </a>

      <button
        id="theme-toggle"
        class="theme-toggle"
        type="button"
        aria-label="Switch to dark mode"
      >
        <svg data-icon="moon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M13.2 9.4A5.6 5.6 0 1 1 6.6 2.8a4.6 4.6 0 0 0 6.6 6.6Z"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linejoin="round"></path>
        </svg>
        <svg data-icon="sun" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="3.2" stroke="currentColor" stroke-width="1.4"></circle>
          <path
            d="M8 1.2v1.6M8 13.2v1.6M1.2 8h1.6M13.2 8h1.6M3.3 3.3l1.1 1.1M11.6 11.6l1.1 1.1M3.3 12.7l1.1-1.1M11.6 4.4l1.1-1.1"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"></path>
        </svg>
      </button>

      <button
        id="menu-btn"
        class="menu-btn"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle menu"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 4.5h12M2 8h12M2 11.5h12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path>
        </svg>
      </button>
    </nav>
  </div>

  <div id="mobile-menu" class="mobile-menu" hidden>
    <div class="wrap mobile-menu__inner">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
      <a class="btn-ink" href={bookingUrl} target="_blank" rel="noopener noreferrer">
        Book a founder call
      </a>
    </div>
  </div>
</header>

<script>
  const button = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (button && menu) {
    const syncState = (expanded: boolean) => {
      button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      menu.hidden = !expanded;
    };

    button.addEventListener('click', () => {
      syncState(button.getAttribute('aria-expanded') !== 'true');
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => syncState(false));
    });
  }

  const themeToggle = document.getElementById('theme-toggle');

  if (themeToggle) {
    const label = (isDark: boolean) =>
      themeToggle.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');

    label(document.documentElement.classList.contains('dark'));

    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      label(isDark);

      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch {}

      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) {
        meta.setAttribute('content', isDark ? '#101012' : '#fafafa');
      }
    });
  }
</script>
