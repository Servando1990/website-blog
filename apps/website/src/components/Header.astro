---
import ThemeToggle from './ThemeToggle';
import { bookingUrl, navigation } from '../lib/siteContent';

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') {
    return pathname === href;
  }

  return pathname.startsWith(href);
}
---

<header class="site-header">
  <div class="site-container">
    <nav class="site-nav" aria-label="Primary">
      <a class="brand-mark" href="/">
        <img
          class="brand-mark__logo invert dark:invert-0"
          src="/controlthrive-logo.svg"
          alt="controlthrive logo"
          width="48"
          height="48"
        />
        <span class="brand-mark__copy">
          <span class="brand-mark__title">controlthrive</span>
          <span class="brand-mark__detail">Founder-led software partner for private capital</span>
        </span>
      </a>

      <div class="nav-actions">
        <div class="nav-links">
          {navigation.map((item) => (
            <a class="nav-link" href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
          <a class="button-secondary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
            Book a founder call
          </a>
        </div>

        <button
          id="mobile-menu-button"
          class="mobile-menu-button"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle menu"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </button>

        <ThemeToggle client:load />
      </div>
    </nav>
  </div>

  <div id="mobile-menu" class="mobile-menu hidden">
    <div class="site-container mobile-menu__inner">
      {navigation.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
      <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
        Book a founder call
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');

    if (!button || !menu) {
      return;
    }

    const syncState = (expanded: boolean) => {
      button.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      menu.classList.toggle('hidden', !expanded);
    };

    syncState(false);

    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      syncState(!isExpanded);
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => syncState(false));
    });
  });
</script>
