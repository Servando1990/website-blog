---
import { bookingUrl, navigation, partnerNetwork } from '../lib/siteContent';
---

<footer class="footer-shell">
  <div class="site-container section-frame">
    <div class="footer-grid">
      <div class="page-stack">
        <span class="eyebrow">ControlThrive</span>
        <h3>Trusted software partnership for private capital teams that need clarity and working systems.</h3>
        <p class="supporting-copy max-w-[34rem]">
          We work with private capital and advisory teams that want a technical partner who can explain tradeoffs clearly, ship carefully, and stay close enough to make the work stick.
        </p>
        <div class="hero-actions">
          <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
            Book a founder call
          </a>
          <a class="button-secondary" href="mailto:servando@controlthrive.com">
            servando@controlthrive.com
          </a>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <div class="footer-link-list">
          <span class="micro-label">Navigate</span>
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>

        <div class="footer-link-list">
          <span class="micro-label">Core ecosystem</span>
          {partnerNetwork.map((partner) => (
            <a href={partner.href} target="_blank" rel="noopener noreferrer">{partner.name}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer-meta">
      <div class="page-stack gap-1">
        <span class="micro-label">Founder-led and remote-first</span>
        <span class="text-sm" style="color: var(--page-muted);">
          ControlThrive partners with decision-makers who want fewer abstractions and more usable software.
        </span>
      </div>

      <div class="page-stack gap-4 md:items-end">
        <div class="social-links">
          <a href="https://x.com/servandotorres" target="_blank" rel="noopener noreferrer" aria-label="Visit ControlThrive on X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.847h-7.405l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932zM17.61 20.644h2.04L6.486 3.24H4.298z" />
            </svg>
          </a>
          <a href="https://linkedin.com/in/servandotorres" target="_blank" rel="noopener noreferrer" aria-label="Visit ControlThrive on LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065M7.119 20.452H3.555V9h3.564zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z" />
            </svg>
          </a>
          <a href="https://github.com/servandotg" target="_blank" rel="noopener noreferrer" aria-label="Visit ControlThrive on GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.38 7.86 10.9.57.1.78-.25.78-.56v-2.02c-3.2.7-3.88-1.35-3.88-1.35-.52-1.33-1.27-1.68-1.27-1.68-1.04-.72.08-.71.08-.71 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.33.95.1-.74.4-1.25.72-1.53-2.56-.29-5.25-1.28-5.25-5.68 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.47.11-3.07 0 0 .96-.31 3.14 1.18a10.9 10.9 0 0 1 5.72 0c2.18-1.49 3.14-1.18 3.14-1.18.62 1.6.23 2.78.11 3.07.74.8 1.18 1.83 1.18 3.09 0 4.41-2.7 5.38-5.28 5.67.42.36.78 1.07.78 2.16v3.2c0 .31.21.67.79.56A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5" />
            </svg>
          </a>
        </div>
        <span class="text-sm" style="color: var(--page-muted);">
          &copy; 2026 ControlThrive. All rights reserved.
        </span>
      </div>
    </div>
  </div>
</footer>
