---
import { bookingUrl, navigation } from '../lib/siteContent';
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="brand" href="/">
          <span class="brand__word">controlthrive</span>
        </a>
        <p>
          Founder-led software studio for private capital teams — production AI
          systems where the judgment stays yours and every output can be traced.
        </p>
      </div>

      <div class="footer-col">
        <span class="mono-label">Navigate</span>
        {navigation.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
        <a href={bookingUrl} target="_blank" rel="noopener noreferrer">Book a call</a>
      </div>

      <div class="footer-col">
        <span class="mono-label">Elsewhere</span>
        <a href="https://x.com/vandotorres" target="_blank" rel="noopener noreferrer">X</a>
        <a href="https://www.linkedin.com/in/servando-torres-239a26b0/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://github.com/Servando1990" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="mailto:servando@controlthrive.com">servando@controlthrive.com</a>
      </div>
    </div>

    <div class="footer-meta">
      <span>&copy; 2026 controlthrive</span>
      <span>Founder-led · Remote-first</span>
    </div>
  </div>
</footer>
