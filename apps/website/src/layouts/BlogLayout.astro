---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBand from '../components/CtaBand.astro';

const {
  frontmatter: {
    title,
    description,
    category = 'Essay',
    publishDate,
    readTime = '12 min read',
    ogImage,
    ogImageAlt,
    ogImageWidth,
    ogImageHeight,
  },
} = Astro.props;
---

<Layout
  title={`${title} | controlthrive`}
  description={description}
  ogType="article"
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  ogImageWidth={ogImageWidth}
  ogImageHeight={ogImageHeight}
>
  <Header />

  <main>
    <section class="page-intro" style="padding-bottom: 0">
      <div class="wrap">
        <div class="meta-row">
          <span>{category}</span>
          <time datetime={publishDate}>{publishDate}</time>
          <span>{readTime}</span>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top: 1.5rem">
      <div class="wrap">
        <article class="prose">
          <slot />
        </article>
      </div>
    </section>

    <CtaBand
      index="02"
      title="Want this workflow mapped against your process?"
      copy="Bring the mandate, investor workflow, or diligence handoff that feels too scattered. We can turn it into a concrete operating path together."
      showPrinciples={false}
    />
  </main>

  <Footer />
</Layout>
