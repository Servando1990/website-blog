---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  ogSiteName?: string;
}

const {
  title,
  description = 'Founder-led AI software partnership for business leaders who need clear strategy, strong delivery, and working systems.',
  ogImage = '/api/og/home.png',
  ogUrl = Astro.url.href,
  ogType = 'website',
  ogSiteName = 'ControlThrive',
} = Astro.props;

const baseUrl = (Astro.site || Astro.url.origin).toString();
const ogVersion =
  process.env.VERCEL_GIT_COMMIT_SHA ||
  process.env.VERCEL_DEPLOYMENT_ID ||
  process.env.OG_IMAGE_VERSION ||
  'local';
const resolvedOgImageUrl = new URL(ogImage, baseUrl);
resolvedOgImageUrl.searchParams.set('v', ogVersion);
const resolvedOgImage = resolvedOgImageUrl.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content={ogSiteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={ogUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <meta name="theme-color" content="#f5efe4" />

    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-LLMXBYB3P8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-LLMXBYB3P8');
    </script>

    <script is:inline>
      const getStoredTheme = () => {
        try {
          return localStorage.getItem('theme');
        } catch {
          return null;
        }
      };

      const preferredTheme = getStoredTheme();
      const resolvedTheme =
        preferredTheme ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

      document.documentElement.classList.toggle('dark', resolvedTheme === 'dark');
      document.documentElement.dataset.theme = resolvedTheme;
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Instrument+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" is:inline>
      {JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'ProfessionalService',
        name: 'ControlThrive',
        founder: {
          '@type': 'Person',
          name: 'Servando Torres',
        },
        email: 'servando@controlthrive.com',
        url: baseUrl,
        description,
        sameAs: [
          'https://x.com/servandotorres',
          'https://linkedin.com/in/servandotorres',
          'https://github.com/servandotg',
        ],
        serviceType: [
          'AI software strategy',
          'Workflow automation',
          'Custom AI product delivery',
        ],
      })}
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
