---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

type BlogPostFrontmatter = {
  title: string;
  cardTitle?: string;
  description: string;
  category?: string;
  publishDate: string;
  readTime?: string;
  ogImage?: string;
  ogImageAlt?: string;
};

type BlogPostModule = {
  frontmatter: BlogPostFrontmatter;
  url: string;
};

const formatDate = (date: string) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(`${date}T00:00:00Z`));

const postModules = Object.values(
  import.meta.glob<BlogPostModule>('./*.md', { eager: true }),
);
const posts = postModules
  .map((post) => ({
    href: post.url,
    title: post.frontmatter.title,
    cardTitle: post.frontmatter.cardTitle ?? post.frontmatter.title,
    description: post.frontmatter.description,
    category: post.frontmatter.category ?? 'Essay',
    publishDate: post.frontmatter.publishDate,
    readTime: post.frontmatter.readTime,
    image: post.frontmatter.ogImage ?? '/api/og/home.png',
    imageAlt: post.frontmatter.ogImageAlt ?? `${post.frontmatter.title} cover image.`,
  }))
  .sort((a, b) => (
    new Date(`${b.publishDate}T00:00:00Z`).getTime()
    - new Date(`${a.publishDate}T00:00:00Z`).getTime()
  ));

const featuredPost = posts[0];
const restPosts = posts.slice(1);
---

<Layout
  title="Writing | controlthrive"
  description="Essays from controlthrive on private capital workflows, investor matching, workflow agents, and production AI systems."
  ogImage={featuredPost?.image}
  ogImageAlt={featuredPost?.imageAlt}
>
  <Header />

  <main>
    <section class="page-intro">
      <div class="wrap">
        <span class="mono-label">Writing</span>
        <h1 class="page-title">
          Essays on private capital workflows and production AI systems.
        </h1>
      </div>
    </section>

    {featuredPost && (
      <section class="section section--ruled" style="padding-top: 0; border-top: 0" aria-label="Latest essay">
        <div class="wrap">
          <article class="work-row" style="border-top: 1px solid var(--hairline)">
            <div class="work-row__meta">
              <span class="mono-label">Latest</span>
              <a class="frame-img" href={featuredPost.href} aria-label={`Read ${featuredPost.title}`}>
                <img src={featuredPost.image} alt={featuredPost.imageAlt} loading="eager" decoding="async" />
              </a>
            </div>
            <div class="work-row__body">
              <h3><a href={featuredPost.href}>{featuredPost.title}</a></h3>
              <p>{featuredPost.description}</p>
              <div class="meta-row" style="margin-top: 1rem">
                <span>{featuredPost.category}</span>
                <time datetime={featuredPost.publishDate}>{formatDate(featuredPost.publishDate)}</time>
                {featuredPost.readTime && <span>{featuredPost.readTime}</span>}
              </div>
              <div class="work-row__links">
                <a class="link-quiet" href={featuredPost.href}>Read essay</a>
              </div>
            </div>
          </article>

          {restPosts.length > 0 && (
            <div class="writing-list">
              {restPosts.map((post) => (
                <article class="writing-row">
                  <time datetime={post.publishDate}>{formatDate(post.publishDate)}</time>
                  <h3><a href={post.href}>{post.cardTitle}</a></h3>
                  <a class="link-quiet" href={post.href}>Read</a>
                  <p>{post.description}</p>
                </article>
              ))}
            </div>
          )}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>
