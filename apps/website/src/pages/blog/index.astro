---
const postUrl = '/blog/deal-investor-matching-architecture';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${postUrl}`} />
    <link rel="canonical" href={postUrl} />
    <title>Redirecting to blog post</title>
    <script is:inline>
      window.location.replace('/blog/deal-investor-matching-architecture');
    </script>
  </head>
  <body>
    <a href={postUrl}>Continue to the latest post</a>
  </body>
</html>
