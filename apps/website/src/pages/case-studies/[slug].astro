---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CtaBand from '../../components/CtaBand.astro';
import InteractiveCaseStudyDiagram from '../../components/InteractiveCaseStudyDiagram';
import { getCaseStudyBySlug, publishedCaseStudies } from '../../lib/caseStudies';
import { caseStudyInlineLinks, renderInlineLinks } from '../../lib/inlineLinks';

export function getStaticPaths() {
  return publishedCaseStudies.map((caseStudy) => ({
    params: { slug: caseStudy.slug },
  }));
}

const slug = Astro.params.slug;
const caseStudy = slug ? getCaseStudyBySlug(slug) : undefined;

if (!caseStudy || !caseStudy.isPublished) {
  throw new Error(`Unknown published case study: ${slug}`);
}

function countWords(text: string) {
  return text.trim().split(/\s+/).filter(Boolean).length;
}

const readTimeSource = [
  caseStudy.title,
  caseStudy.summary,
  caseStudy.featuredOutcome,
  ...caseStudy.challenge,
  ...caseStudy.design,
  ...caseStudy.implementationHighlights,
  ...caseStudy.result,
  caseStudy.takeaway,
  ...caseStudy.facts.flatMap((fact) => [fact.label, fact.value]),
  ...caseStudy.metrics.flatMap((metric) => [metric.value, metric.label]),
  caseStudy.diagram.title,
  caseStudy.diagram.subtitle,
  ...caseStudy.diagram.steps.flatMap((step) => [step.title, step.summary, step.detail, step.metric]),
].join(' ');

const readTimeMinutes = Math.max(1, Math.ceil(countWords(readTimeSource) / 220));

const relatedStudies = publishedCaseStudies.filter((study) => study.slug !== caseStudy.slug).slice(0, 2);
const inlineLinks = caseStudyInlineLinks[caseStudy.slug] ?? [];
---

<Layout
  title={`${caseStudy.title} | controlthrive`}
  description={caseStudy.summary}
  ogType="article"
  ogImage={`/api/og/case-studies/${caseStudy.slug}.png`}
>
  <Header />

  <main>
    <section class="page-intro">
      <div class="wrap">
        <a class="link-quiet" href="/case-studies" style="margin-bottom: 2.5rem">
          All case studies
        </a>

        <div class="meta-row" style="margin-top: 2.5rem">
          <span>{caseStudy.industry}</span>
          <span>{readTimeMinutes} min read</span>
        </div>

        <h1 class="page-title">{caseStudy.title}</h1>
        <p class="page-lede">{caseStudy.summary}</p>

        <div class="facts-grid">
          {caseStudy.facts.map((fact) => (
            <div>
              <span>{fact.label}</span>
              <strong>{fact.value}</strong>
            </div>
          ))}
        </div>

        {caseStudy.proofLink ? (
          <div style="margin-top: 1.75rem">
            <a class="link-quiet" href={caseStudy.proofLink.href} target="_blank" rel="noopener noreferrer">
              {caseStudy.proofLink.label}
            </a>
          </div>
        ) : null}
      </div>
    </section>

    <section class="section section--ruled">
      <div class="wrap article-grid">
        <article class="prose">
          <section>
            <span class="mono-label">What was at stake</span>
            <h2>The business problem behind the build.</h2>
            {caseStudy.challenge.map((paragraph) => (
              <p set:html={renderInlineLinks(paragraph, inlineLinks)} />
            ))}
          </section>

          <section>
            <span class="mono-label">What we built</span>
            <h2>A system designed for real decision-making.</h2>
            {caseStudy.design.map((paragraph) => (
              <p set:html={renderInlineLinks(paragraph, inlineLinks)} />
            ))}
          </section>

          <section>
            <span class="mono-label">Implementation highlights</span>
            <h2>The decisions that made the workflow hold up.</h2>
            <ul>
              {caseStudy.implementationHighlights.map((item) => (
                <li set:html={renderInlineLinks(item, inlineLinks)} />
              ))}
            </ul>
            <InteractiveCaseStudyDiagram
              client:load
              title={caseStudy.diagram.title}
              subtitle={caseStudy.diagram.subtitle}
              steps={caseStudy.diagram.steps}
            />
          </section>

          <section>
            <span class="mono-label">What changed</span>
            <h2>Result</h2>
            {caseStudy.result.map((paragraph) => (
              <p set:html={renderInlineLinks(paragraph, inlineLinks)} />
            ))}
          </section>

          <section>
            <span class="mono-label">Takeaway</span>
            <h2>What this work says about how controlthrive builds.</h2>
            <p set:html={renderInlineLinks(caseStudy.takeaway, inlineLinks)} />
          </section>
        </article>

        {caseStudy.metrics.length > 0 ? (
          <aside aria-label="Delivery snapshot">
            <span class="mono-label">Delivery snapshot</span>
            <ul class="snapshot" style="margin-top: 1rem">
              {caseStudy.metrics.map((metric) => (
                <li>
                  <strong>{metric.value}</strong>
                  <span>{metric.label}</span>
                </li>
              ))}
            </ul>
          </aside>
        ) : null}
      </div>
    </section>

    <CtaBand
      index="02"
      title="Have a similar workflow in mind?"
      copy="Bring the process, bottleneck, or review workflow you want to improve. We can sort out whether it needs a workshop, a lighter decision layer, or a full build."
      showPrinciples={false}
    />

    <section class="section section--ruled">
      <div class="wrap">
        <header class="sec-head">
          <span class="sec-head__index">03</span>
          <span class="sec-head__label">More work</span>
        </header>

        <div class="work-list">
          {relatedStudies.map((study) => (
            <article class="work-row">
              <div class="work-row__meta">
                <span class="mono-label">{study.industry}</span>
                <p class="work-row__outcome">{study.featuredOutcome}</p>
              </div>
              <div class="work-row__body">
                <h3>
                  <a href={`/case-studies/${study.slug}`}>{study.title}</a>
                </h3>
                <p>{study.cardSummary}</p>
                <div class="work-row__links">
                  <a class="link-quiet" href={`/case-studies/${study.slug}`}>
                    Read this case study
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
