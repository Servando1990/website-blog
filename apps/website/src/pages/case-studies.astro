---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { bookingUrl } from '../lib/siteContent';
import { publishedCaseStudies } from '../lib/caseStudies';
---

<Layout
  title="Case Studies | controlthrive"
  description="Selected controlthrive case studies showing how founder-led software work supports private capital, advisory, and adjacent research workflows."
>
  <Header />

  <main class="site-main">
    <section class="section-frame">
      <div class="site-container page-stack">
        <div class="page-intro">
          <span class="eyebrow">Case studies</span>
          <h1 class="display-title display-title--compact">
            Delivery stories for private capital teams and adjacent operators.
          </h1>
          <p class="lede">
            These projects show what it looks like when controlthrive works as a close software
            partner: clear workflow framing, careful system design, and delivery that stands up in
            day-to-day use.
          </p>
        </div>
      </div>
    </section>

    <section class="section-frame section-divider">
      <div class="site-container case-list">
        {publishedCaseStudies.map((study) => (
          <article class="case-card">
            <div class="case-card__meta">
              <span class="label-chip">{study.industry}</span>
              <p class="featured-study__outcome">{study.featuredOutcome}</p>
            </div>

            <div class="case-card__content">
              <h2 class="text-[2rem] md:text-[2.55rem]">{study.title}</h2>
              <p class="case-card__summary">{study.cardSummary}</p>

              <div class="hero-actions">
                <a class="button-primary" href={`/case-studies/${study.slug}`}>
                  Read the case study
                </a>
                {study.proofLink ? (
                  <a class="text-link" href={study.proofLink.href} target="_blank" rel="noopener noreferrer">
                    {study.proofLink.label}
                  </a>
                ) : null}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section-frame section-divider">
      <div class="site-container">
        <div class="cta-band">
          <div class="cta-band__grid">
            <div class="page-stack">
              <span class="eyebrow">Work with controlthrive</span>
              <h2 class="section-title">Need a technical partner who can make the path feel concrete?</h2>
              <p class="supporting-copy max-w-[36rem]">
                If you are evaluating an investor workflow, monitoring process, or internal tool,
                we can pressure-test the idea together and define the right next build.
              </p>
            </div>

            <div class="page-stack lg:items-end">
              <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
                Book a founder call
              </a>
              <a class="button-secondary" href="/tools">
                Explore the tools first
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
