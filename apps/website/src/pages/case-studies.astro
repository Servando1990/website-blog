---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBand from '../components/CtaBand.astro';
import { publishedCaseStudies } from '../lib/caseStudies';
---

<Layout
  title="Case Studies | controlthrive"
  description="Selected controlthrive case studies showing how founder-led software work supports private capital, advisory, and adjacent research workflows."
>
  <Header />

  <main>
    <section class="page-intro">
      <div class="wrap">
        <span class="mono-label">Case studies</span>
        <h1 class="page-title">
          Delivery stories for private capital teams and adjacent operators.
        </h1>
        <p class="page-lede">
          What it looks like when controlthrive works as a close software
          partner: clear workflow framing, careful system design, and delivery
          that stands up in day-to-day use.
        </p>
      </div>
    </section>

    <section class="section section--ruled" style="padding-top: 0; border-top: 0">
      <div class="wrap">
        <div class="work-list">
          {publishedCaseStudies.map((study) => (
            <article class="work-row">
              <div class="work-row__meta">
                <span class="mono-label">{study.industry}</span>
                <p class="work-row__outcome">{study.featuredOutcome}</p>
              </div>
              <div class="work-row__body">
                <h3>
                  <a href={`/case-studies/${study.slug}`}>{study.title}</a>
                </h3>
                <p>{study.cardSummary}</p>
                <div class="work-row__links">
                  <a class="link-quiet" href={`/case-studies/${study.slug}`}>
                    Read case study
                  </a>
                  {study.proofLink ? (
                    <a class="link-quiet" href={study.proofLink.href} target="_blank" rel="noopener noreferrer">
                      {study.proofLink.label}
                    </a>
                  ) : null}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <CtaBand
      index="02"
      title="Need a technical partner who can make the path feel concrete?"
      copy="If you are evaluating an investor workflow, monitoring process, or internal tool, we can pressure-test the idea together and define the right next build."
      showPrinciples={false}
    />
  </main>

  <Footer />
</Layout>
