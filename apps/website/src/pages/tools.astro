---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CtaBand from '../components/CtaBand.astro';
import { bookingUrl, tools } from '../lib/siteContent';
---

<Layout
  title="Tools | controlthrive"
  description="Lightweight controlthrive diagnostics for teams that want a clearer view before committing to a larger workflow build."
>
  <Header />

  <main>
    <section class="page-intro">
      <div class="wrap">
        <span class="mono-label">Tools</span>
        <h1 class="page-title">
          Quick diagnostics before a larger workflow build.
        </h1>
        <p class="page-lede">
          Built to help a team sharpen the conversation before a bigger
          delivery effort starts. Use them when you want signal, not a sales
          funnel.
        </p>
      </div>
    </section>

    <section class="section section--ruled" style="padding-top: 0; border-top: 0">
      <div class="wrap">
        <div class="work-list">
          {tools.map((tool) => (
            <article class="tool-row">
              <div>
                <span class="mono-label">Tool</span>
                <h3 style="margin-top: 0.8rem">{tool.name}</h3>
              </div>
              <div class="tool-row__copy">
                <p>{tool.summary}</p>
                <p>{tool.audience}</p>
                <p>{tool.outcome}</p>
                <div class="tool-row__actions">
                  <a class="btn-ink" href={tool.href} target="_blank" rel="noopener noreferrer">
                    {tool.ctaLabel}
                  </a>
                  <a class="btn-line" href={bookingUrl} target="_blank" rel="noopener noreferrer">
                    Talk to the founder instead
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <CtaBand
      index="02"
      title="Sometimes the fastest route is getting the workflow on the table."
      copy="If the problem is high-stakes, messy, or tied to multiple teams, a founder call is usually the better starting point. We can sort the priorities together and decide whether a tool, workshop, or build makes the most sense."
      showPrinciples={false}
    />
  </main>

  <Footer />
</Layout>
