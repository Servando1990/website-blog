---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { bookingUrl, tools } from '../lib/siteContent';
---

<Layout
  title="Tools | ControlThrive"
  description="Self-serve ControlThrive tools for decision-makers who want a clearer view of AI readiness and data opportunity before a larger build."
>
  <Header />

  <main class="site-main">
    <section class="section-frame">
      <div class="site-container page-stack">
        <div class="page-intro">
          <span class="eyebrow">Tools</span>
          <h1 class="display-title display-title--compact">
            Quick diagnostics for leaders who want a clearer next move.
          </h1>
          <p class="lede">
            These tools are built to help decision-makers sharpen the conversation before a bigger
            delivery effort starts. Use them when you want signal, not a sales funnel.
          </p>
        </div>
      </div>
    </section>

    <section class="section-frame section-divider">
      <div class="site-container tool-grid">
        {tools.map((tool) => (
          <article class="tool-card">
            <span class="label-chip">Self-serve tool</span>
            <h2>{tool.name}</h2>
            <p>{tool.summary}</p>
            <div class="grid gap-3">
              <div class="fact-item">
                <span>Best for</span>
                <strong>{tool.audience}</strong>
              </div>
              <div class="fact-item">
                <span>What you get</span>
                <strong>{tool.outcome}</strong>
              </div>
            </div>
            <div class="hero-actions">
              <a class="button-primary" href={tool.href} target="_blank" rel="noopener noreferrer">
                {tool.ctaLabel}
              </a>
              <a class="button-secondary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
                Talk to the founder instead
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section-frame section-divider">
      <div class="site-container">
        <div class="cta-band">
          <div class="cta-band__grid">
            <div class="page-stack">
              <span class="eyebrow">Prefer a conversation?</span>
              <h2 class="section-title">Sometimes the fastest route is just getting the workflow on the table.</h2>
              <p class="supporting-copy max-w-[36rem]">
                If the problem is complex, high-stakes, or tied to multiple teams, a founder call is
                usually the better starting point. We can sort the priorities together and decide
                whether a tool, workshop, or build makes the most sense.
              </p>
            </div>

            <div class="page-stack lg:items-end">
              <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
                Book a founder call
              </a>
              <a class="button-secondary" href="/case-studies">
                Review the work first
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
