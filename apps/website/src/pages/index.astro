---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { HeroTrajectoryField } from '../components/HeroTrajectoryField';
import {
  bookingUrl,
  founderProfile,
  serviceAreas,
  testimonials,
  trustPrinciples,
} from '../lib/siteContent';
import { publishedCaseStudies } from '../lib/caseStudies';

const featuredCaseStudies = publishedCaseStudies.slice(0, 3);

const privateCapitalAgentRows = [
  { step: 1, workflow: 'Define the mandate', agent: 'Structure the deal into a clear opportunity profile.', phase: 'Setup' },
  { step: 2, workflow: 'Package the opportunity', agent: 'Extract, normalize, and flag gaps in deal materials.', phase: 'Setup' },
  { step: 3, workflow: 'Define the investor profile / thesis', agent: 'Turn the mandate into investor-fit criteria, exclusions, and thesis nuance.', phase: 'Setup' },
  { step: 4, workflow: 'Search the investor universe', agent: 'Find likely-fit investors across CRM memory and external sources.', phase: 'Search' },
  { step: 5, workflow: 'Prioritize matches', agent: 'Rank investors by fit and explain the rationale, signals, risks, and constraints.', phase: 'Search' },
  { step: 6, workflow: 'Prepare outreach / handoff', agent: 'Preserve deal and relationship context for outreach, export, sequence, or review handoff.', phase: 'Search' },
  { step: 7, workflow: 'Support investor triage', agent: "Screen the deal against the investor's thesis and route the next action.", phase: 'Review' },
  { step: 8, workflow: 'Verify company data', agent: 'Pre-fill intake, flag gaps or inconsistencies, and ask the company to confirm.', phase: 'Review' },
  { step: 9, workflow: 'Prepare diligence', agent: 'Create memo-ready analysis, scorecards, risk flags, and follow-up questions.', phase: 'Review' },
  { step: 10, workflow: 'Analyze structure', agent: 'Compare deal structures, constraints, and return implications using deterministic math.', phase: 'Decision' },
  { step: 11, workflow: 'Move toward LOI / term sheet', agent: 'Summarize open issues, term-sheet readiness, and decision points.', phase: 'Decision' },
  { step: 12, workflow: 'Support close', agent: 'Track final diligence, legal items, approvals, and follow-ups.', phase: 'Decision' },
  { step: 13, workflow: 'Monitor, pass, or nurture', agent: 'Capture pass rationale, set reminders, and suggest better-fit future paths.', phase: 'Memory' },
];

const privateCapitalAgentPhases = ['Setup', 'Search', 'Review', 'Decision', 'Memory'];
---

<Layout
  title="controlthrive | Software Partner for Private Capital Teams"
  description="Founder-led software partner for private capital teams that need clearer investor workflows, portfolio monitoring, and internal systems that hold up in practice."
  ogImage="/api/og/home.png"
>
  <Header />

  <main class="site-main hermes-page">
    <section class="hermes-hero">
      <div class="hermes-noise" aria-hidden="true"></div>
      <div class="hermes-float hermes-float--one" aria-hidden="true"></div>
      <div class="hermes-float hermes-float--two" aria-hidden="true"></div>
      <HeroTrajectoryField client:load />

      <div class="hermes-hero__inner">
        <span class="hermes-eyebrow">Founder-led software partner for private capital</span>
        <h1 class="hermes-title">controlthrive</h1>
        <p class="hermes-kicker">
          We partner with private capital teams to turn their context into production AI
        </p>

        <div class="hermes-command-list" aria-label="Engagement flow">
          <div class="hermes-command">
            <div class="hermes-command__meta">
              <span>1. Scope</span>
              <a href={bookingUrl} target="_blank" rel="noopener noreferrer">Open</a>
            </div>
            <code>book founder call --workflow "private capital"</code>
          </div>
          <div class="hermes-command">
            <div class="hermes-command__meta">
              <span>2. Build</span>
              <a href="/case-studies">View</a>
            </div>
            <code>ship evidence-linked system --with adoption</code>
          </div>
        </div>
      </div>
    </section>

    <section class="hermes-action">
      <div class="hermes-section-title">
        <span>See It In Action</span>
      </div>

      <div class="hermes-agent-map" aria-labelledby="agent-workflow-title">
        <div class="hermes-agent-map__intro">
          <div>
            <span class="hermes-eyebrow">Private capital</span>
            <h2 id="agent-workflow-title">What agents can do across the workflow</h2>
          </div>
          <p>
            The useful version of automation is not autonomous dealmaking. It is tighter handoffs,
            cleaner memory, and faster synthesis around the people making the call.
          </p>

          <div class="hermes-agent-map__stats" aria-label="Workflow summary">
            <div>
              <strong>{privateCapitalAgentRows.length}</strong>
              <span>workflow steps</span>
            </div>
            <div>
              <strong>{privateCapitalAgentPhases.length}</strong>
              <span>operating phases</span>
            </div>
          </div>

          <div class="hermes-agent-phases" aria-label="Workflow phases">
            {privateCapitalAgentPhases.map((phase) => (
              <span data-phase={phase}>
                <i aria-hidden="true"></i>
                {phase}
              </span>
            ))}
          </div>
        </div>

        <div class="hermes-agent-table-shell">
          <div class="hermes-agent-table-wrap" role="region" aria-label="Private capital agent workflow table" tabindex="0">
            <table class="hermes-agent-table">
              <caption>Agent workflow map from mandate to LOI</caption>
              <thead>
                <tr>
                  <th scope="col">Step</th>
                  <th scope="col">Workflow</th>
                  <th scope="col">What an agent can do</th>
                  <th scope="col">Phase</th>
                </tr>
              </thead>
              <tbody>
                {privateCapitalAgentRows.map((row) => (
                  <tr data-phase={row.phase}>
                    <td class="hermes-agent-table__step" data-label="Step">
                      <span>{row.step}</span>
                    </td>
                    <td class="hermes-agent-table__workflow" data-label="Workflow">
                      {row.workflow}
                    </td>
                    <td class="hermes-agent-table__agent" data-label="What an agent can do">
                      <span aria-hidden="true"></span>
                      {row.agent}
                    </td>
                    <td class="hermes-agent-table__phase" data-label="Phase">
                      <span>{row.phase}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p class="hermes-agent-table-note">
            Less wasted motion between mandate and LOI.
          </p>
        </div>
      </div>
    </section>

    <section class="hermes-feature-grid">
      <div class="hermes-section-title">
        <span>Features</span>
      </div>

      <div class="hermes-feature-grid__inner">
        {serviceAreas.map((service) => (
          <article class="hermes-feature">
            <span>{service.title}</span>
            <p>{service.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="hermes-split-section">
      <div class="hermes-section-title">
        <span>Selected work</span>
      </div>

      <div class="hermes-study-list">
        {featuredCaseStudies.map((study) => (
          <article class="hermes-study">
            <div>
              <span>{study.industry}</span>
              <h2>{study.title}</h2>
            </div>
            <p>{study.cardSummary}</p>
            <a href={`/case-studies/${study.slug}`}>Read case study</a>
          </article>
        ))}
      </div>
    </section>

    <section class="hermes-testimonial-section">
      <div class="hermes-testimonial-intro">
        <span class="hermes-eyebrow">Client Perspective</span>
        <h2>Built for teams that want a partner, not a pitch.</h2>
      </div>

      <div class="hermes-testimonial-rail" aria-label="Client testimonials">
        {testimonials.map((testimonial, index) => (
          <blockquote style={`--testimonial-index: ${index}`}>
            <p>“{testimonial.quote}”</p>
            <cite>
              <strong>{testimonial.name}</strong>
              <span>{testimonial.role} • {testimonial.company}</span>
            </cite>
          </blockquote>
        ))}
      </div>
    </section>

    <section class="hermes-split-section hermes-split-section--two">
      <div class="hermes-panel">
        <span class="hermes-eyebrow">Founder-led</span>
        <div class="hermes-founder-copy">
          {founderProfile.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      <div class="hermes-panel hermes-panel--image">
        <img src="/profile-pic.jpg" alt="Portrait of Servando Torres, founder of controlthrive" />
        <div>
          <span class="hermes-eyebrow">Founder-led</span>
          <p>Servando Torres, Founder</p>
        </div>
      </div>
    </section>

    <section class="hermes-feature-grid">
      <div class="hermes-section-title">
        <span>Built for trust</span>
      </div>

      <div class="hermes-feature-grid__inner">
        {trustPrinciples.map((principle) => (
          <article class="hermes-feature">
            <span>{principle.title}</span>
            <p>{principle.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="hermes-cta">
      <div>
        <span class="hermes-eyebrow">Next step</span>
        <h2>If the workflow matters, the software path should feel clear.</h2>
      </div>
      <div class="hermes-cta__actions">
        <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
          Book a founder call
        </a>
        <a class="button-secondary" href="mailto:servando@controlthrive.com">
          Email controlthrive
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
