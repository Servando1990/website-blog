---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { HeroAsciiField } from '../components/HeroAsciiField';
import {
  bookingUrl,
  founderProfile,
  serviceAreas,
  testimonials,
  trustPrinciples,
} from '../lib/siteContent';
import { publishedCaseStudies } from '../lib/caseStudies';

const featuredCaseStudies = publishedCaseStudies.slice(0, 3);
---

<Layout
  title="controlthrive | Software Partner for Private Capital Teams"
  description="Founder-led software partner for private capital teams that need clearer investor workflows, portfolio monitoring, and internal systems that hold up in practice."
  ogImage="/api/og/home.png"
>
  <Header />

  <main class="site-main hermes-page">
    <section class="hermes-hero">
      <div class="hermes-noise" aria-hidden="true"></div>
      <div class="hermes-float hermes-float--one" aria-hidden="true"></div>
      <div class="hermes-float hermes-float--two" aria-hidden="true"></div>

      <div class="hermes-hero__inner">
        <span class="hermes-eyebrow">Founder-led • private capital systems</span>
        <h1 class="hermes-title">CONTROL THRIVE</h1>
        <p class="hermes-kicker">
          Production AI workflows for investor coverage, portfolio monitoring, and internal
          operating systems that learn with the team.
        </p>

        <div class="hermes-command-list" aria-label="Engagement flow">
          <div class="hermes-command">
            <div class="hermes-command__meta">
              <span>1. Scope</span>
              <a href={bookingUrl} target="_blank" rel="noopener noreferrer">Open</a>
            </div>
            <code>book founder call --workflow "private capital"</code>
          </div>
          <div class="hermes-command">
            <div class="hermes-command__meta">
              <span>2. Build</span>
              <a href="/case-studies">View</a>
            </div>
            <code>ship evidence-linked system --with adoption</code>
          </div>
        </div>
      </div>
    </section>

    <section class="hermes-action">
      <div class="hermes-section-title">
        <span>See It In Action</span>
      </div>

      <div class="hermes-action__grid">
        <div class="hermes-terminal" aria-label="Simulated terminal workflow">
          <div class="hermes-terminal__bar">
            <span></span>
            <span></span>
            <span></span>
            <strong>controlthrive</strong>
          </div>
          <div class="hermes-terminal__body">
            <p><span>›</span> Review investor coverage gaps for MVV Capital</p>
            <p><span>›</span> Attach source evidence and rank next outreach</p>
            <p><span>›</span> Generate operator-ready workflow brief<span class="terminal-caret"></span></p>
          </div>
        </div>

        <div class="hermes-engraving">
          <HeroAsciiField client:load />
          <span>CONTROLTHRIVE</span>
        </div>
      </div>
    </section>

    <section class="hermes-feature-grid">
      <div class="hermes-section-title">
        <span>Features</span>
      </div>

      <div class="hermes-feature-grid__inner">
        {serviceAreas.map((service) => (
          <article class="hermes-feature">
            <span>{service.title}</span>
            <p>{service.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="hermes-split-section">
      <div class="hermes-section-title">
        <span>Selected Work</span>
      </div>

      <div class="hermes-study-list">
        {featuredCaseStudies.map((study) => (
          <article class="hermes-study">
            <div>
              <span>{study.industry}</span>
              <h2>{study.title}</h2>
            </div>
            <p>{study.cardSummary}</p>
            <a href={`/case-studies/${study.slug}`}>Read case study</a>
          </article>
        ))}
      </div>
    </section>

    <section class="hermes-split-section hermes-split-section--two">
      <div class="hermes-panel">
        <span class="hermes-eyebrow">Client Perspective</span>
        <h2>Built for teams that want a partner, not a pitch.</h2>
        <div class="hermes-quotes">
          {testimonials.slice(0, 2).map((testimonial) => (
            <blockquote>
              <p>“{testimonial.quote}”</p>
              <cite>{testimonial.name} • {testimonial.company}</cite>
            </blockquote>
          ))}
        </div>
      </div>

      <div class="hermes-panel hermes-panel--image">
        <img src="/profile-pic.jpg" alt="Portrait of Servando Torres, founder of controlthrive" />
        <div>
          <span class="hermes-eyebrow">Founder-led</span>
          <p>{founderProfile.paragraphs[0]}</p>
        </div>
      </div>
    </section>

    <section class="hermes-feature-grid">
      <div class="hermes-section-title">
        <span>Built For Trust</span>
      </div>

      <div class="hermes-feature-grid__inner">
        {trustPrinciples.map((principle) => (
          <article class="hermes-feature">
            <span>{principle.title}</span>
            <p>{principle.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="hermes-cta">
      <div>
        <span class="hermes-eyebrow">Next Step</span>
        <h2>If the workflow matters, the software path should feel clear.</h2>
      </div>
      <div class="hermes-cta__actions">
        <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
          Book a founder call
        </a>
        <a class="button-secondary" href="mailto:servando@controlthrive.com">
          Email controlthrive
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
