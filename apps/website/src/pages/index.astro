---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { HeroAsciiField } from '../components/HeroAsciiField';
import { HeroTrajectoryField } from '../components/HeroTrajectoryField';
import {
  bookingUrl,
  founderProfile,
  testimonials,
  trustPrinciples,
} from '../lib/siteContent';
import { publishedCaseStudies } from '../lib/caseStudies';

const featuredCaseStudies = publishedCaseStudies.slice(0, 3);

const latestBlogPost = {
  href: '/blog',
  eyebrow: 'Latest blog',
  title: 'From Search to LOI',
  subtitle: 'Why private capital needs workflow agents',
  image: '/blog/search-to-loi-image.jpg',
  alt: 'Pink flowers growing across a textured stone wall.',
};

const operatingBridge = [
  {
    label: 'Context',
    summary: 'Gather the mandate, materials, relationship memory, and constraints that usually live in different places.',
  },
  {
    label: 'Ship',
    summary: 'Feed context to agents and ship systems that turn messy workflow inputs into usable decision support.',
  },
  {
    label: 'Iterate',
    summary: 'Refine logic with new context, operator feedback, and evidence so the system keeps producing trusted outputs.',
  },
];

const privateCapitalAgentRows = [
  { step: 1, workflow: 'Define the mandate', agent: 'Structure the deal into a clear opportunity profile.', phase: 'Setup' },
  { step: 2, workflow: 'Package the opportunity', agent: 'Extract, normalize, and flag gaps in deal materials.', phase: 'Setup' },
  { step: 3, workflow: 'Define the investor profile / thesis', agent: 'Turn the mandate into investor-fit criteria, exclusions, and thesis nuance.', phase: 'Setup' },
  { step: 4, workflow: 'Search the investor universe', agent: 'Find likely-fit investors across CRM memory and external sources.', phase: 'Search' },
  { step: 5, workflow: 'Prioritize matches', agent: 'Rank investors by fit and explain the rationale, signals, risks, and constraints.', phase: 'Search' },
  { step: 6, workflow: 'Prepare outreach / handoff', agent: 'Preserve deal and relationship context for outreach, export, sequence, or review handoff.', phase: 'Search' },
  { step: 7, workflow: 'Support investor triage', agent: "Screen the deal against the investor's thesis and route the next action.", phase: 'Review' },
  { step: 8, workflow: 'Verify company data', agent: 'Pre-fill intake, flag gaps or inconsistencies, and ask the company to confirm.', phase: 'Review' },
  { step: 9, workflow: 'Prepare diligence', agent: 'Create memo-ready analysis, scorecards, risk flags, and follow-up questions.', phase: 'Review' },
  { step: 10, workflow: 'Analyze structure', agent: 'Compare deal structures, constraints, and return implications using deterministic math.', phase: 'Decision' },
  { step: 11, workflow: 'Move toward LOI / term sheet', agent: 'Summarize open issues, term-sheet readiness, and decision points.', phase: 'Decision' },
  { step: 12, workflow: 'Support close', agent: 'Track final diligence, legal items, approvals, and follow-ups.', phase: 'Decision' },
  { step: 13, workflow: 'Monitor, pass, or nurture', agent: 'Capture pass rationale, set reminders, and suggest better-fit future paths.', phase: 'Memory' },
];
---

<Layout
  title="controlthrive | Software Partner for Private Capital Teams"
  description="Founder-led software partner for private capital teams that need clearer investor workflows, portfolio monitoring, and internal systems that hold up in practice."
  ogImage="/api/og/home.png"
>
  <Header />

  <main class="site-main hermes-page">
    <section class="hermes-hero">
      <div class="hermes-noise" aria-hidden="true"></div>
      <div class="hermes-float hermes-float--one" aria-hidden="true"></div>
      <div class="hermes-float hermes-float--two" aria-hidden="true"></div>
      <HeroTrajectoryField client:load />

      <div class="hermes-hero__inner">
        <span class="hermes-eyebrow">Founder-led software partner for private capital</span>
        <h1 class="hermes-title">
          <span>control</span>
          <span>thrive</span>
        </h1>
        <p class="hermes-kicker">
          We partner with private capital teams to turn their context into production AI
        </p>

        <div class="hermes-command-list" aria-label="Engagement flow">
          <div class="hermes-command">
            <div class="hermes-command__meta">
              <span>1. Scope</span>
              <a href={bookingUrl} target="_blank" rel="noopener noreferrer">Open</a>
            </div>
            <code>talk to founder --system "private capital"</code>
          </div>
          <div class="hermes-command">
            <div class="hermes-command__meta">
              <span>2. Build</span>
              <a href="/case-studies">View</a>
            </div>
            <code>run case studies --view</code>
          </div>
        </div>
      </div>
    </section>

    <section class="hermes-action" data-agent-action data-agent-rows={JSON.stringify(privateCapitalAgentRows)}>
      <div class="hermes-action__grid">
        <div class="hermes-terminal hermes-terminal--agent" aria-label="Human and agent private capital workflow exchange">
          <div class="hermes-terminal__bar">
            <span></span>
            <span></span>
            <span></span>
            <strong>human-agent-run</strong>
          </div>
          <div class="hermes-terminal__body hermes-agent-cli">
            <p class="hermes-agent-cli__prompt">
              <span>›</span> replay --human-sets-step --agent-responds --speed fast
            </p>

            <div class="hermes-agent-cli__stream" aria-label="Human instruction and agent response log" aria-live="polite">
              <article class="hermes-agent-turn" data-agent-turn data-phase={privateCapitalAgentRows[0].phase}>
                <p class="hermes-agent-turn__line">
                  <span class="hermes-agent-turn__prompt">human sets</span>
                  <span class="hermes-agent-turn__meta" data-agent-meta>{String(privateCapitalAgentRows[0].step).padStart(2, '0')} / {privateCapitalAgentRows[0].phase}</span>
                  <span class="hermes-agent-turn__instruction" data-agent-instruction>{privateCapitalAgentRows[0].workflow}</span>
                </p>
                <p class="hermes-agent-turn__line hermes-agent-turn__line--agent">
                  <span class="hermes-agent-turn__prompt hermes-agent-turn__prompt--agent">agent replies</span>
                  <span class="hermes-agent-turn__response" data-agent-response>{privateCapitalAgentRows[0].agent}</span>
                </p>
              </article>

              <div class="hermes-agent-cli__progress" aria-hidden="true">
                <span data-agent-progress></span>
              </div>
            </div>

            <p class="hermes-agent-cli__prompt hermes-agent-cli__prompt--final" data-agent-status>
              <span>›</span> running step 01/13 --human_decision=pending<span class="terminal-caret"></span>
            </p>
          </div>
        </div>

        <div class="hermes-engraving">
          <HeroAsciiField client:load />
        </div>
      </div>
    </section>

    <script is:inline>
      (() => {
        const action = document.querySelector('[data-agent-action]');

        if (!action) {
          return;
        }

        let turns = [];
        try {
          turns = JSON.parse(action.getAttribute('data-agent-rows') || '[]');
        } catch {
          turns = [];
        }

        const turn = action.querySelector('[data-agent-turn]');
        const meta = action.querySelector('[data-agent-meta]');
        const instruction = action.querySelector('[data-agent-instruction]');
        const response = action.querySelector('[data-agent-response]');
        const status = action.querySelector('[data-agent-status]');
        const progress = action.querySelector('[data-agent-progress]');

        if (!turn || !meta || !instruction || !response || !status || !turns.length) {
          return;
        }

        let activeIndex = 0;
        let cycleTimer;
        let replyTimer;

        const renderTurn = (index) => {
          const row = turns[index % turns.length];
          const nextRow = turns[(index + 1) % turns.length];
          const paddedStep = String(row.step).padStart(2, '0');

          window.clearTimeout(replyTimer);
          turn.dataset.phase = row.phase;
          turn.dataset.reply = 'pending';
          turn.classList.remove('hermes-agent-turn--active');
          void turn.offsetWidth;

          meta.textContent = `${paddedStep} / ${row.phase}`;
          instruction.textContent = row.workflow;
          response.textContent = row.agent;
          status.innerHTML = `<span>›</span> running step ${paddedStep}/${turns.length} --human_decision=pending<span class="terminal-caret"></span>`;

          if (progress) {
            progress.style.transform = `scaleX(${row.step / turns.length})`;
          }

          turn.classList.add('hermes-agent-turn--active');

          replyTimer = window.setTimeout(() => {
            turn.dataset.reply = 'ready';
            const isLastStep = row.step === turns.length;
            status.innerHTML = isLastStep
              ? '<span>›</span> handoff ready --human_decision=true<span class="terminal-caret"></span>'
              : `<span>›</span> step ${paddedStep} complete --next=${String(nextRow.step).padStart(2, '0')}<span class="terminal-caret"></span>`;
          }, 760);
        };

        const startReplay = () => {
          if (cycleTimer) {
            return;
          }

          renderTurn(activeIndex);
          cycleTimer = window.setInterval(() => {
            activeIndex = (activeIndex + 1) % turns.length;
            renderTurn(activeIndex);
          }, 2600);
        };

        action.classList.add('hermes-action--ready');

        const activate = () => {
          action.classList.add('hermes-action--live');
          startReplay();
        };

        if (!('IntersectionObserver' in window)) {
          activate();
          return;
        }

        const observer = new IntersectionObserver(
          ([entry]) => {
            if (entry?.isIntersecting) {
              activate();
              observer.disconnect();
            }
          },
          { rootMargin: '-12% 0px -18%', threshold: 0.18 },
        );

        observer.observe(action);
      })();
    </script>

    <section class="hermes-announcement" aria-label="Latest blog post">
      <a class="hermes-announcement__inner" href={latestBlogPost.href}>
        <figure class="hermes-announcement__image">
          <img src={latestBlogPost.image} alt={latestBlogPost.alt} loading="eager" decoding="async" />
        </figure>

        <div class="hermes-announcement__copy">
          <span>{latestBlogPost.eyebrow}</span>
          <h2>{latestBlogPost.title}</h2>
          <p>{latestBlogPost.subtitle}</p>
        </div>

        <span class="hermes-announcement__cta">Read post</span>
      </a>
    </section>

    <section class="hermes-operating-bridge" aria-label="Operating focus">
      <div class="hermes-operating-bridge__copy">
        <span class="hermes-eyebrow">Operating focus</span>
        <h2>Turn scattered context into a handoff someone can act on.</h2>
      </div>

      <ol class="hermes-operating-steps">
        {operatingBridge.map((step, index) => (
          <li style={`--bridge-index: ${index}`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{step.label}</strong>
            <p>{step.summary}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="hermes-split-section">
      <div class="hermes-section-title">
        <span>Selected work</span>
      </div>

      <div class="hermes-study-list">
        {featuredCaseStudies.map((study) => (
          <article class="hermes-study">
            <div>
              <span>{study.industry}</span>
              <h2>{study.title}</h2>
            </div>
            <p>{study.cardSummary}</p>
            <a href={`/case-studies/${study.slug}`}>Read case study</a>
          </article>
        ))}
      </div>
    </section>

    <section class="hermes-testimonial-section">
      <div class="hermes-testimonial-intro">
        <span class="hermes-eyebrow">Client Perspective</span>
        <h2>Built for teams that want a partner, not a pitch.</h2>
      </div>

      <div class="hermes-testimonial-rail" aria-label="Client testimonials">
        {testimonials.map((testimonial, index) => (
          <blockquote style={`--testimonial-index: ${index}`}>
            <p>“{testimonial.quote}”</p>
            <cite>
              <strong>{testimonial.name}</strong>
              <span>{testimonial.role} • {testimonial.company}</span>
            </cite>
          </blockquote>
        ))}
      </div>
    </section>

    <section class="hermes-split-section hermes-split-section--two">
      <div class="hermes-panel">
        <span class="hermes-eyebrow">Founder-led</span>
        <div class="hermes-founder-copy">
          {founderProfile.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      <div class="hermes-panel hermes-panel--image">
        <img src="/profile-pic.jpg" alt="Portrait of Servando Torres, founder of controlthrive" />
        <div>
          <span class="hermes-eyebrow">Founder-led</span>
          <p>Servando Torres, Founder</p>
        </div>
      </div>
    </section>

    <section class="hermes-feature-grid">
      <div class="hermes-section-title">
        <span>Built for trust</span>
      </div>

      <div class="hermes-feature-grid__inner">
        {trustPrinciples.map((principle) => (
          <article class="hermes-feature">
            <span>{principle.title}</span>
            <p>{principle.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="hermes-cta">
      <div>
        <span class="hermes-eyebrow">Next step</span>
        <h2>If the workflow matters, the software path should feel clear.</h2>
      </div>
      <div class="hermes-cta__actions">
        <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
          Book a founder call
        </a>
        <a class="button-secondary" href="mailto:servando@controlthrive.com">
          Email controlthrive
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
