---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  bookingUrl,
  founderProfile,
  serviceAreas,
  trustedCompanies,
} from '../lib/siteContent';
import { publishedCaseStudies } from '../lib/caseStudies';

const featuredCaseStudies = publishedCaseStudies.slice(0, 2);
---

<Layout
  title="ControlThrive | Trusted AI Software Partner for Business Leaders"
  description="Founder-led AI software partnership for business owners and decision-makers who need clear strategy, strong delivery, and working systems."
  ogImage="/api/og/home.png"
>
  <Header />

  <main class="site-main">
    <section class="section-frame">
      <div class="site-container page-stack">
        <div class="hero-grid">
          <div class="hero-copy">
            <span class="eyebrow">Founder-led AI software partnership</span>
            <h1 class="display-title">
              We help business leaders turn AI ambition into working software.
            </h1>
            <p class="lede">
              ControlThrive works like a trusted technical partner: clarifying the opportunity,
              designing the right workflow, and staying close through delivery so your team gets a
              system it can actually use.
            </p>
            <div class="hero-actions">
              <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
                Book a founder call
              </a>
              <a class="button-secondary" href="/case-studies">
                See recent work
              </a>
            </div>
          </div>

          <aside class="hero-panel surface-panel-strong">
            <span class="label-chip">How we show up</span>
            <h2 class="hero-panel__title">
              Warm, direct guidance from the first conversation to the rollout.
            </h2>
            <p class="hero-panel__body">
              Most clients do not need more AI language. They need a partner who can explain
              tradeoffs clearly, make the product path concrete, and stay close enough that the
              work survives contact with the business.
            </p>
            <ul class="trust-list">
              <li>Strategy starts with the commercial problem, not the model choice.</li>
              <li>Delivery is shaped around the workflow your team already owns.</li>
              <li>Founder-led continuity means less friction, fewer handoffs, and faster trust.</li>
            </ul>
          </aside>
        </div>

        <div class="trust-strip">
          <span class="trust-strip__label">Trusted by teams from</span>
          <div class="trust-strip__list">
            {trustedCompanies.map((company) => (
              <span>{company}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-frame section-divider">
      <div class="site-container editorial-grid">
        <div class="page-stack">
          <span class="eyebrow">What the partnership covers</span>
          <h2 class="section-title">Three ways we usually help.</h2>
          <p class="supporting-copy max-w-[34rem]">
            We work best with decision-makers who want a technical partner that can translate
            business context into software without turning the process into a spectacle.
          </p>
        </div>

        <div class="stack-list">
          {serviceAreas.map((service) => (
            <article class="service-block">
              <h3>{service.title}</h3>
              <p>{service.summary}</p>
              <p class="mt-3">{service.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-frame section-divider">
      <div class="site-container page-stack">
        <div class="page-intro">
          <span class="eyebrow">Selected work</span>
          <h2 class="section-title">Proof from delivery, not from promises.</h2>
          <p class="supporting-copy max-w-[40rem]">
            These are the kinds of systems we build when leaders need a trusted technical partner
            and a clear path from idea to execution.
          </p>
        </div>

        <div class="featured-study-list">
          {featuredCaseStudies.map((study) => (
            <article class="featured-study">
              <div class="page-stack gap-4">
                <span class="label-chip">{study.industry}</span>
                <p class="featured-study__outcome">{study.featuredOutcome}</p>
              </div>

              <div class="page-stack gap-5">
                <h3 class="text-[2rem] md:text-[2.5rem]">{study.title}</h3>
                <p class="featured-study__summary">{study.cardSummary}</p>
                <div class="hero-actions">
                  <a class="button-primary" href={`/case-studies/${study.slug}`}>
                    Read the case study
                  </a>
                  <a class="button-ghost" href="/case-studies">
                    View all work
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-frame section-divider">
      <div class="site-container founder-grid">
        <div class="founder-photo">
          <img src="/profile-pic.jpg" alt="Portrait of Servando Torres, founder of ControlThrive" />
        </div>

        <div class="founder-note">
          <span class="eyebrow">Who you work with</span>
          <h2 class="section-title">{founderProfile.title}</h2>
          <p class="supporting-copy">{founderProfile.summary}</p>
          <p class="supporting-copy">{founderProfile.note}</p>
          <div class="hero-actions">
            <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
              Talk to Servando
            </a>
            <a class="button-secondary" href="/case-studies">
              Explore the work
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-frame section-divider">
      <div class="site-container">
        <div class="cta-band">
          <div class="cta-band__grid">
            <div class="page-stack">
              <span class="eyebrow">Next step</span>
              <h2 class="section-title">
                If the business problem is real, the software path should feel clear.
              </h2>
              <p class="supporting-copy max-w-[36rem]">
                Bring the workflow, decision, or opportunity you are trying to improve. We can sort
                out what deserves a product, what needs a lighter intervention, and how to move
                without adding more noise.
              </p>
            </div>

            <div class="page-stack lg:items-end">
              <a class="button-primary" href={bookingUrl} target="_blank" rel="noopener noreferrer">
                Book a founder call
              </a>
              <a class="button-secondary" href="mailto:servando@controlthrive.com">
                Email ControlThrive
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
